  <Code><![CDATA[# Dot-source Globals if not already loaded by Startup (safe-guard)
# This ensures that any globally defined functions or variables are available for this script.
if (-not (Get-Command Invoke-Ui -ErrorAction SilentlyContinue))
{
	# Check if the script is running in a context where its root path is defined
	if ($PSScriptRoot -and (Test-Path (Join-Path $PSScriptRoot 'Globals.ps1')))
	{
		# Load the Globals.ps1 script
		. (Join-Path $PSScriptRoot 'Globals.ps1')
	}
}

#region ---- UI Logging & Dialog helpers ----

# Function to write log messages to a UI element or the console
function Write-UiLog
{
	param (
		\[string\]$Message,
		\[ValidateSet('INFO', 'WARN', 'ERROR', 'DEBUG')\]
		\[string\]$Level = 'INFO',
		\[switch\]$Echo
	)
	# Check if a global textbox for logging is defined
	if (Test-Path variable:\\global:textboxLog)
	{
		$tb = Get-Variable -Name textboxLog -Scope Global -ValueOnly -ErrorAction SilentlyContinue
		if ($tb -is \[System.Windows.Forms.TextBoxBase\])
		{
			# Prepend the log level to the message and append it to the textbox
			$prefix = "\[{0}\] " -f $Level
			Append-UiText -TextBox $tb -Text ($prefix + $Message)
		}
		else
		{
			# Fallback to console output if the textbox is not a valid control
			switch ($Level)
			{
				'ERROR' { Write-Error $Message }
				'WARN'  { Write-Warning $Message }
				'DEBUG' { Write-Verbose $Message }
				default { Write-Information $Message -InformationAction Continue }
			}
		}
	}
	else
	{
		# If no textbox is defined, write to the appropriate console stream based on the level
		switch ($Level)
		{
			'ERROR' { Write-Error $Message }
			'WARN'  { Write-Warning $Message }
			'DEBUG' { Write-Verbose $Message }
			default { Write-Information $Message -InformationAction Continue }
		}
	}
	
	# If the -Echo switch is present, also write the message to the standard log
	if ($Echo -and (Get-Command Write-Log -ErrorAction SilentlyContinue))
	{
		Write-Log -Message $Message -Level $Level
	}
}

# Wrapper functions to show simple message boxes
function Show-Info(\[string\]$msg, \[string\]$title = 'Information')
{
	\[void\]\[System.Windows.Forms.MessageBox\]::Show($msg, $title, 'OK', 'Information')
}

function Show-Warn(\[string\]$msg, \[string\]$title = 'Warning')
{
	\[void\]\[System.Windows.Forms.MessageBox\]::Show($msg, $title, 'OK', 'Warning')
}

function Show-Error(\[string\]$msg, \[string\]$title = 'Error')
{
	\[void\]\[System.Windows.Forms.MessageBox\]::Show($msg, $title, 'OK', 'Error')
}

# Function to show a confirmation dialog with Yes/No buttons
function Confirm-YesNo(\[string\]$msg, \[string\]$title = 'Confirm')
{
	$res = \[System.Windows.Forms.MessageBox\]::Show($msg, $title, 'YesNo', 'Question')
	return ($res -eq \[System.Windows.Forms.DialogResult\]::Yes)
}

#endregion

#region ---- Utility helpers ----

# Formats a byte value into a human-readable string (B, kB, MB, GB, etc.)
Function Format-Bytes
{
	Param (
		\[Parameter(ValueFromPipeline = $true)\]
		\[ValidateNotNullOrEmpty()\]
		\[decimal\]$Bytes
	)
	
	$kB = 1000
	$MB = $kB \* 1000
	$GB = $MB \* 1000
	$TB = $GB \* 1000
	$PB = $TB \* 1000
	
	if ($Bytes -lt $kB) { return ("{0:N0} B" -f $Bytes) }
	elseif ($Bytes -lt $MB) { return ("{0:N2} kB" -f ($Bytes / $kB)) }
	elseif ($Bytes -lt $GB) { return ("{0:N2} MB" -f ($Bytes / $MB)) }
	elseif ($Bytes -lt $TB) { return ("{0:N2} GB" -f ($Bytes / $GB)) }
	elseif ($Bytes -lt $PB) { return ("{0:N2} TB" -f ($Bytes / $TB)) }
	else { return ("{0:N2} PB" -f ($Bytes / $PB)) }
}

# Checks for the existence of a path and optionally creates it if it's missing.
function Ensure-Path(\[Parameter(Mandatory)\]\[string\]$Path, \[switch\]$MustExist, \[switch\]$CreateIfMissing)
{
	if (Test-Path -Path $Path) { return $true }
	if ($CreateIfMissing)
	{
		try { New-Item -ItemType Directory -Path $Path -Force | Out-Null; return $true }
		catch { }
	}
	if ($MustExist) { return $false }
	return $true
}

# Retrieves the selected disk number from a combobox.
function Get-SelectedDiskNumber
{
	$num = $combobox1.SelectedItem
	if ($null -eq $num -or $num -as \[int\] -isnot \[int\]) { return $null }
	return \[int\]$num
}

# Writes colored text to the console if the PSWriteColor module is available.
function Write-ColorSafe
{
	param (\[string\[\]\]$Text,
		\[ConsoleColor\[\]\]$Color)
	if (Get-Command Write-Color -ErrorAction SilentlyContinue)
	{
		Write-Color -Text $Text -Color $Color
	}
	else
	{
		# Fallback to the UI log if the module is not present.
		Write-UiLog -Message ($Text -join '') -Level INFO
	}
}

#endregion

#region ---- Data binding helpers ----

# Updates a DataGridView control with items from a data source.
function Update-DataGridView
{
	Param (
		\[Parameter(Mandatory)\]
		\[ValidateNotNull()\]
		\[System.Windows.Forms.DataGridView\]$DataGridView,
		\[Parameter(Mandatory)\]
		\[ValidateNotNull()\]
		$Item,
		\[string\]$DataMember,
		\[System.Windows.Forms.DataGridViewAutoSizeColumnsMode\]$AutoSizeColumns = 'None'
	)
	# Suspend layout updates for performance while making changes.
	$DataGridView.SuspendLayout()
	$DataGridView.DataMember = $DataMember
	
	if ($null -eq $Item)
	{
		$DataGridView.DataSource = $null
	}
	elseif ($Item -is \[System.Data.DataSet\] -and $Item.Tables.Count -gt 0)
	{
		$DataGridView.DataSource = $Item.Tables\[0\]
	}
	elseif ($Item -is \[System.ComponentModel.IListSource\] -or $Item -is \[System.ComponentModel.IBindingList\] -or $Item -is \[System.ComponentModel.IBindingListView\])
	{
		$DataGridView.DataSource = $Item
	}
	else
	{
		# Convert a single item or a collection to an ArrayList to be used as a data source.
		$array = New-Object System.Collections.ArrayList
		if ($Item -is \[System.Collections.IList\]) { $array.AddRange($Item) }
		else { $null = $array.Add($Item) }
		$DataGridView.DataSource = $array
	}
	
	# Auto-resize columns if requested.
	if ($AutoSizeColumns -ne 'None') { $DataGridView.AutoResizeColumns($AutoSizeColumns) }
	# Resume layout updates.
	$DataGridView.ResumeLayout()
}

# Updates a ComboBox control with a list of items.
function Update-ComboBox
{
	param (
		\[Parameter(Mandatory)\]
		\[ValidateNotNull()\]
		\[System.Windows.Forms.ComboBox\]$ComboBox,
		\[Parameter(Mandatory)\]
		\[ValidateNotNull()\]
		$Items,
		\[string\]$DisplayMember,
		\[string\]$ValueMember,
		\[switch\]$Append
	)
	# Clear existing items unless appending.
	if (-not $Append) { $ComboBox.Items.Clear() }
	
	if ($Items -is \[object\[\]\])
	{
		$ComboBox.Items.AddRange($Items)
	}
	elseif ($Items -is \[System.Collections.IEnumerable\])
	{
		# Use BeginUpdate/EndUpdate for performance when adding many items.
		$ComboBox.BeginUpdate()
		foreach ($obj in $Items) { $null = $ComboBox.Items.Add($obj) }
		$ComboBox.EndUpdate()
	}
	else
	{
		$null = $ComboBox.Items.Add($Items)
	}
	
	# Set the properties used to display the items and determine their values.
	if ($DisplayMember) { $ComboBox.DisplayMember = $DisplayMember }
	if ($ValueMember) { $ComboBox.ValueMember = $ValueMember }
}

# Updates a ListBox control with a list of items.
function Update-ListBox
{
	param (
		\[Parameter(Mandatory)\]
		\[ValidateNotNull()\]
		\[System.Windows.Forms.ListBox\]$ListBox,
		\[Parameter(Mandatory)\]
		\[ValidateNotNull()\]
		$Items,
		\[string\]$DisplayMember,
		\[string\]$ValueMember,
		\[switch\]$Append
	)
	if (-not $Append) { $ListBox.Items.Clear() }
	
	if ($Items -is \[System.Windows.Forms.ListBox+ObjectCollection\] -or $Items -is \[System.Collections.ICollection\])
	{
		$ListBox.Items.AddRange($Items)
	}
	elseif ($Items -is \[System.Collections.IEnumerable\])
	{
		$ListBox.BeginUpdate()
		foreach ($obj in $Items) { $null = $ListBox.Items.Add($obj) }
		$ListBox.EndUpdate()
	}
	else
	{
		$null = $ListBox.Items.Add($Items)
	}
	
	if ($DisplayMember) { $ListBox.DisplayMember = $DisplayMember }
	if ($ValueMember) { $ListBox.ValueMember = $ValueMember }
}

#endregion

#region ---- Domain-specific loaders ----

# Scans a directory for TeraByte Image (.tbi) files and populates a combobox with the findings.
function Load-TBI-Files
{
	try
	{
		if (\[string\]::IsNullOrWhiteSpace($default_tbi_imagepath))
		{
			Write-UiLog "TBI image path variable is empty/null." -Level ERROR
			return
		}
		
		$tbiRoot = $default_tbi_imagepath
		Write-UiLog "Scanning TBI root: $tbiRoot"
		
		if (-not (Test-Path -Path $tbiRoot -PathType Container))
		{
			Write-UiLog "TBI images folder not found: $tbiRoot" -Level WARN
			return
		}
		
		# Find all .tbi files recursively. Use a fallback method if the first fails.
		$files = Get-ChildItem -Path $tbiRoot -Filter \*.tbi -Recurse -File -ErrorAction SilentlyContinue
		if (-not $files -or $files.Count -eq 0)
		{
			$files = Get-ChildItem -Path $tbiRoot -Recurse -ErrorAction SilentlyContinue |
			Where-Object { -not $\_.PSIsContainer -and $\_.Name -match '\\.tbi$' }
		}
		
		$count = ($files | Measure-Object).Count
		if ($count -le 0)
		{
			Write-UiLog "No \*.tbi files found under $tbiRoot." -Level WARN
			return
		}
		
		# Populate the combobox with the file names.
		$names = $files | Select-Object -ExpandProperty Name
		$combobox2.BeginUpdate()
		$combobox2.Items.Clear()
		$combobox2.Items.AddRange(\[object\[\]\]$names)
		$combobox2.EndUpdate()
		
		if ($combobox2.Items.Count -gt 0) { $combobox2.SelectedIndex = 0 }
		
		Write-UiLog "Loaded $count TBI file(s) from $tbiRoot."
	}
	catch
	{
		Write-UiLog "Load-TBI-Files failed: $($\_.Exception.Message)" -Level ERROR
	}
}

# Core implementation for loading script folders into a combobox.
function LoadScriptsCore
{
	try
	{
		$root = $default_scriptpath
		if (\[string\]::IsNullOrWhiteSpace($root))
		{
			Write-UiLog "Scripts path variable is empty/null." -Level ERROR
			return
		}
		if (-not (Test-Path $root -PathType Container))
		{
			Write-UiLog "Scripts root not found: $root" -Level WARN
			return
		}
		
		$scripts = Get-ChildItem -Path $root -Directory -ErrorAction SilentlyContinue |
		Select-Object -ExpandProperty Name
		
		$combobox3.BeginUpdate()
		$combobox3.Items.Clear()
		if ($scripts) { $combobox3.Items.AddRange(\[object\[\]\]$scripts) }
		$combobox3.EndUpdate()
		
		if ($combobox3.Items.Count -gt 0) { $combobox3.SelectedIndex = 0 }
		
		Write-UiLog "Loaded $($scripts.Count) script folder(s) from $root."
	}
	catch
	{
		Write-UiLog "Load scripts failed: $($\_.Exception.Message)" -Level ERROR
	}
}

# Create aliases for the script loading function for backward compatibility.
Set-Item -Path function:\\Load-Scripts -Value ${function:LoadScriptsCore} -ErrorAction SilentlyContinue
Set-Item -Path function:\\LoadScripts -Value ${function:LoadScriptsCore} -ErrorAction SilentlyContinue
Set-Item -Path function:\\loadscripts -Value ${function:LoadScriptsCore} -ErrorAction SilentlyContinue

#endregion

#region ---- DaRT launcher ----

# Launches the Microsoft Diagnostics and Recovery Toolset (DaRT).
function Launch-DART
{
	# Gather basic system information.
	$cpu_model = $null; $OSArchitecture = $null
	try { $cpu_model = (Get-CimInstance Win32_ComputerSystem -ErrorAction Stop).Model }
	catch { }
	try { $OSArchitecture = (Get-CimInstance Win32_OperatingSystem -ErrorAction Stop).OSArchitecture }
	catch { }
	
	$cpuText = if (\[string\]::IsNullOrWhiteSpace($cpu_model)) { 'Unknown' }
	else { $cpu_model }
	$archText = if (\[string\]::IsNullOrWhiteSpace($OSArchitecture)) { 'Unknown' }
	else { $OSArchitecture }
	
	# Display a header with system info.
	Write-ColorSafe -Text @('==========================================================================') -Color Cyan
	Write-ColorSafe -Text @('SSIS: ', 'Microsoft DaRT') -Color @(\[ConsoleColor\]::White, \[ConsoleColor\]::Magenta)
	Write-ColorSafe -Text @('Computer Model: ', $cpuText, ' | ARCH: (', $archText, ')') -Color @(\[ConsoleColor\]::White, \[ConsoleColor\]::Green, \[ConsoleColor\]::White, \[ConsoleColor\]::Green, \[ConsoleColor\]::White)
	Write-ColorSafe -Text @('==========================================================================') -Color Cyan
	
	Write-UiLog "Listing available Windows installations.."
	
	# Find all available Windows installations on the system.
	$validwins = New-Object System.Collections.Generic.List\[object\]
	$validwins.Add(\[PSCustomObject\]@{ Name = 'Cancel Task'; Root = ''; Number = 0; Size = 0 })
	$num = 1
	
	$FileSystems = Get-PSDrive | Where-Object Provider -Match 'FileSystem'
	foreach ($fsys in $FileSystems)
	{
		$candidateRoot = '{0}Windows' -f $fsys.Root
		if ($fsys.Name -ne 'X' -and $candidateRoot -ne $runningwin)
		{
			if (Test-Path -Path $candidateRoot -PathType Container)
			{
				$validwins.Add(\[PSCustomObject\]@{
						Name   = $fsys.Name
						Root   = $fsys.Root
						Size   = $fsys.Used
						Number = $num
					})
				$num++
			}
		}
	}
	
	$max = $num - 1
	if ($max -gt 0)
	{
		# Prompt the user to select a Windows volume.
		$ok = $false
		do
		{
			$validwins | Format-Table Number, Name, Root, @{ Label = 'Size(Used)'; Expression = { Format-Bytes $\_.Size } } | Out-String | Write-UiLog
			$inputString = Read-Host 'Please select the Windows Volume (0 to cancel)'
			$vol = $inputString -as \[int\]
			$ok = ($null -ne $vol -and $vol -ge 0 -and $vol -le $max)
			if ($vol -eq 0) { Write-UiLog "Canceling Task.. Returning to Menu." -Level WARN; return }
			if (-not $ok) { Write-UiLog 'You must select a valid Windows volume!' -Level WARN }
		}
		until ($ok)
		
		$chosen = $validwins | Where-Object Number -eq $vol
		Write-UiLog ("You have selected: {0} ({1})" -f $chosen.Name, $chosen.Root)
		
		# Set the selected Windows installation as the target for recovery.
		New-Item -Path 'HKLM:\\SOFTWARE\\Microsoft\\RecoveryEnvironment' -Force | Out-Null
		New-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\RecoveryEnvironment' -Name TargetOS -PropertyType String -Value ("{0}\\Windows" -f $chosen.Root.TrimEnd('\\')) -Force | Out-Null
	}
	
	# Launch the DaRT executable.
	$dartExe = Join-Path $ssismain 'apps\\Microsoft_DaRT\\MSDartTools.exe'
	if (-not (Test-Path $dartExe -PathType Leaf)) { Show-Error "DaRT not found: $dartExe"; return }
	Start-Process -FilePath $dartExe -WorkingDirectory (Split-Path $dartExe -Parent) -WindowStyle Normal -Wait
}

#endregion

#region ---- Imaging helpers ----

# Gets the full path to the selected TBI file.
function Get-TBI-Path
{
	$fileName = $combobox2.SelectedItem
	if (\[string\]::IsNullOrWhiteSpace($fileName)) { Show-Warn "No TBI file selected."; return $null }
	$tbiPath = Join-Path $default_tbi_imagepath $fileName
	if (-not (Test-Path $tbiPath -PathType Leaf)) { Show-Error "TBI file not found:\`r\`n$tbiPath"; return $null }
	return $tbiPath
}

# Gets the full path to the selected post-install script folder.
function Get-SelectedScriptFolder
{
	$sel = $combobox3.SelectedItem
	if (\[string\]::IsNullOrWhiteSpace($sel)) { return $null }
	$full = Join-Path $default_scriptpath $sel
	if (-not (Test-Path $full -PathType Container)) { Show-Error "Script folder not found:\`r\`n$full"; return $null }
	return $full
}

# Updates the computer name in a post-install script.
function Update-RenameComputerScript(\[string\]$ScriptFolder, \[string\]$NewComputerName)
{
	$file = Join-Path $ScriptFolder 'RenameComputer.ps1'
	if (-not (Test-Path $file -PathType Leaf))
	{
		Write-UiLog "RenameComputer.ps1 not found in $ScriptFolder" -Level WARN
		return
	}
	try
	{
		# Read the script content, replace the computer name, and write it back.
		$data = Get-Content -Path $file -ErrorAction Stop
		$tagname = 'ComputerName'
		$find = "$tagname=(.\*)"
		$replace = "$tagname=$NewComputerName"
		($data -replace $find, $replace) | Set-Content -Path $file -Encoding UTF8
		Write-UiLog "Updated RenameComputer.ps1 with ComputerName=$NewComputerName"
	}
	catch
	{
		Write-UiLog "Failed updating RenameComputer.ps1: $($\_.Exception.Message)" -Level ERROR
	}
}

# Restores a disk image from a TBI file to a specified disk.
function Invoke-ImageRestore(\[int\]$DiskNumber, \[string\]$TbiPath)
{
	$imagew = Join-Path $default_appspath 'ImageW_LD\\imagew.exe'
	if (-not (Test-Path $imagew -PathType Leaf)) { Show-Error "Imaging tool not found:\`r\`n$imagew"; return $false }
	try
	{
		Write-UiLog "Clearing disk $DiskNumber (OEM & data)..." -Level WARN
		# Clear all partitions and data from the target disk.
		Clear-Disk -Number $DiskNumber -RemoveData -RemoveOEM -Confirm:$false -ErrorAction SilentlyContinue | Out-Null
		
		$start = Get-Date
		Write-UiLog "Imaging started..."
		$args = "/r /o /x /d:{0} /priority:4 /dpc /rb:0 /f:{1}" -f $DiskNumber, ('"{0}"' -f $TbiPath)
		# Start the imaging process and wait for it to complete.
		$p = Start-Process -FilePath $imagew -ArgumentList $args -Wait -PassThru -WindowStyle Hidden
		$elapsed = (Get-Date) - $start
		Write-UiLog ("Imaging completed. Runtime: {0} min(s)" -f \[int\]$elapsed.TotalMinutes)
		return ($p.ExitCode -eq 0)
	}
	catch
	{
		Write-UiLog "Imaging failed: $($\_.Exception.Message)" -Level ERROR
		return $false
	}
	finally
	{
		# Ensure the disk is brought back online after imaging.
		try { if ((Get-Disk -Number $DiskNumber).IsOffline) { Set-Disk -Number $DiskNumber -IsOffline:$false } }
		catch { }
	}
}

# Assigns drive letters to partitions on a disk and detects the Windows partition.
function Assign-DriveLettersAndDetectWindows(\[int\]$DiskNumber)
{
	$CurrentLetter = \[byte\]\[char\]'P' # Assign letters in descending order
	$sys = 'S'
	$rec = 'R'
	$basic = @()
	$windrive = $null
	
	$parts = Get-Partition -DiskNumber $DiskNumber -ErrorAction SilentlyContinue
	foreach ($p in $parts)
	{
		if ($p.Type -eq 'System')
		{
			$p | Set-Partition -NewDriveLetter $sys -ErrorAction SilentlyContinue
		}
		elseif ($p.Type -eq 'Basic')
		{
			$p | Set-Partition -NewDriveLetter (\[char\]$CurrentLetter) -ErrorAction SilentlyContinue
			$basic += \[PSCustomObject\]@{ Letter = (\[char\]$CurrentLetter) }
			$CurrentLetter--
		}
		elseif ($p.Type -eq 'Recovery')
		{
			$p | Set-Partition -NewDriveLetter $rec -ErrorAction SilentlyContinue
		}
	}
	# Find the drive letter of the partition containing the Windows folder.
	foreach ($b in $basic)
	{
		if (Test-Path -Path ("{0}:\\Windows\\System32" -f $b.Letter) -PathType Container) { $windrive = $b.Letter; break }
	}
	return $windrive
}

# Injects post-installation scripts and unattended answer files into the restored Windows image.
function Inject-PostInstall(\[char\]$WindowsDrive, \[string\]$ScriptFolder, \[string\]$UnattendDefaultPath)
{
	# Clean up any previous post-install artifacts.
	Remove-Item -Path ("{0}:\\Windows\\Setup\\Scripts\\SetupComplete.cmd" -f $WindowsDrive) -Force -ErrorAction SilentlyContinue
	Remove-Item -Path ("{0}:\\Windows\\Sun" -f $WindowsDrive) -Force -Recurse -ErrorAction SilentlyContinue
	Remove-Item -Path ("{0}:\\ldprovisioning" -f $WindowsDrive) -Force -Recurse -ErrorAction SilentlyContinue
	
	if ($ScriptFolder)
	{
		Write-UiLog "Injecting post-install script(s) from $ScriptFolder..."
		$dst = ("{0}:\\ProgramData\\Dev_Sys_Setup\\Post_Setup" -f $WindowsDrive)
		Ensure-Path -Path $dst -CreateIfMissing | Out-Null
		Copy-Item -Path $ScriptFolder -Destination $dst -Recurse -Force -ErrorAction SilentlyContinue
		
		# Copy the unattend.xml from the script folder if it exists.
		$unattendFromScript = Join-Path $ScriptFolder 'unattend.xml'
		if (Test-Path $unattendFromScript -PathType Leaf)
		{
			$panther = ("{0}:\\Windows\\Panther" -f $WindowsDrive)
			Ensure-Path -Path $panther -CreateIfMissing | Out-Null
			Copy-Item -Path $unattendFromScript -Destination (Join-Path $panther 'unattend.xml') -Force
		}
	}
	else
	{
		# Otherwise, use the default unattend file.
		if (Test-Path $UnattendDefaultPath -PathType Leaf)
		{
			$panther = ("{0}:\\Windows\\Panther" -f $WindowsDrive)
			Ensure-Path -Path $panther -CreateIfMissing | Out-Null
			Copy-Item -Path $UnattendDefaultPath -Destination (Join-Path $panther 'unattend.xml') -Force
		}
	}
}

# Sets the computer name within the unattend.xml file.
function Set-UnattendHostname(\[char\]$WindowsDrive, \[string\]$Hostname)
{
	$pantherUnattend = ("{0}:\\Windows\\Panther\\unattend.xml" -f $WindowsDrive)
	if (-not (Test-Path $pantherUnattend -PathType Leaf)) { Write-UiLog "No unattend.xml found at $pantherUnattend" -Level WARN; return }
	try
	{
		# Replace a placeholder with the desired hostname.
		$content = Get-Content $pantherUnattend
		$content = $content | ForEach-Object { $\_ -replace 'PROVISIONING', $Hostname }
		$content | Set-Content $pantherUnattend -Encoding UTF8
		Write-UiLog "Hostname injected in unattend.xml: $Hostname"
	}
	catch
	{
		Write-UiLog "Failed to set hostname in unattend.xml: $($\_.Exception.Message)" -Level ERROR
	}
}

#endregion

#region ---- Form Load ----

# Event handler for the main form's Load event.
$formSSISSimpleSeatImagin_Load = {
	try
	{
		# Optionally load the PSWriteColor module if it's available.
		$pwModule = Join-Path $default_modulespath 'pswritecolor'
		if (Test-Path $pwModule)
		{
			try { Import-Module -Name $pwModule -Force -ErrorAction Stop }
			catch { }
		}
		
		# Populate the disk selection combobox.
		Update-ComboBox $combobox1 (Get-Disk | Select-Object -ExpandProperty Number)
		
		# Populate listboxes with detailed information about each disk.
		$Disks = Get-Disk | Select-Object Number, FriendlyName, BusType, @{ Name = 'Size'; Expression = { Format-Bytes $\_.Size } }
		foreach ($Disk in $Disks)
		{
			$line = "{0} - {1} - {2} - {3}" -f $Disk.Number, $Disk.FriendlyName, $Disk.Bustype, $Disk.Size
			Update-ListBox $listbox1 $line -Append
			Update-ListBox $listbox2 $line -Append
		}
		
		# Load TBI files and script folders into their respective comboboxes.
		if (Test-Path -Path $default_tbi_imagepath -PathType Container)
		{
			Load-TBI-Files
		}
		else
		{
			Write-UiLog "TBI images folder not found: $default_tbi_imagepath" -Level WARN
		}
		
		# Call the script loading function, trying various possible names for compatibility.
		if (Get-Command Load-Scripts -ErrorAction SilentlyContinue)
		{
			Load-Scripts
		}
		elseif (Get-Command LoadScripts -ErrorAction SilentlyContinue)
		{
			LoadScripts
		}
		elseif (Get-Command loadscripts -ErrorAction SilentlyContinue)
		{
			loadscripts
		}
		else
		{
			LoadScriptsCore
		}
		
		# Show or hide buttons for external tools based on whether their executables exist.
		$button10.Visible = Test-Path (Join-Path $ssismain 'apps\\FarbarRecoveryScanTool\\FRST64.exe')
		$button9.Visible = Test-Path (Join-Path $ssismain 'apps\\BitLockerTool\\BitLockerTool.ps1')
		$button5.Visible = Test-Path (Join-Path $ssismain 'apps\\Microsoft_DaRT\\MSDartTools.exe')
		
		# Optional: Bind a global variable to a textbox control for logging.
		# $global:textboxLog = $yourLogRichTextBoxControl
		
		Write-UiLog "Main form initialized."
	}
	catch
	{
		Write-UiLog "Form load failed: $($\_.Exception.Message)" -Level ERROR
		Show-Error "Initialization failed:\`r\`n$($\_.Exception.Message)"
	}
}

#endregion

#region ---- Button: GO (Restore image) ----

# Event handler for the main "GO" button to start the image restoration process.
$buttonGo_Click = {
	try
	{
		# Get user selections from the UI.
		$diskNumber = Get-SelectedDiskNumber
		if ($null -eq $diskNumber) { Show-Warn "Pick a target disk."; return }
		$targetdrive = (Get-Disk -Number $diskNumber).FriendlyName
		
		$hostnameRaw = $textbox1.Text
		if (\[string\]::IsNullOrWhiteSpace($hostnameRaw)) { Show-Warn "Enter a computer name."; return }
		$hostnameQuoted = ('"{0}"' -f $hostnameRaw)
		
		$scriptFolder = Get-SelectedScriptFolder
		if ($scriptFolder) { Update-RenameComputerScript -ScriptFolder $scriptFolder -NewComputerName $hostnameQuoted }
		
		$tbiPath = Get-TBI-Path
		if (-not $tbiPath) { return }
		
		$targetwin = ($radiobuttonWindows.Checked -eq $true)
		
		# Confirm the imaging operation with the user.
		$summary = @"
Host name: $hostnameRaw
Target Disk: $targetdrive
Target drive number: $diskNumber
Post Install Script Injection: $scriptFolder
TBI file path: $tbiPath
Is Windows? $targetwin

ALL DATA ON THE SELECTED DISK WILL BE ERASED.

Proceed?
"@
		if (-not (Confirm-YesNo $summary 'Confirm Imaging')) { Write-UiLog 'User cancelled imaging.' -Level WARN; return }
		
		# Start the image restore process.
		if (-not (Invoke-ImageRestore -DiskNumber $diskNumber -TbiPath $tbiPath)) { return }
		
		# If the target is a Windows installation, perform post-restore tasks.
		if ($targetwin)
		{
			$windrive = Assign-DriveLettersAndDetectWindows -DiskNumber $diskNumber
			if (-not $windrive) { Show-Error "Failed to detect Windows volume. Please review partitions."; return }
			
			# Find a fallback unattend.xml file if needed.
			$unattendFallback = Join-Path $default_unattendpath 'unattend_default_NOSCRIPT.xml'
			if (-not (Test-Path $unattendFallback -PathType Leaf))
			{
				$unattendCandidate = Get-ChildItem -Path $default_unattendpath -Recurse -Filter unattend.xml -ErrorAction SilentlyContinue | Select-Object -First 1
				if ($unattendCandidate) { $unattendFallback = $unattendCandidate.FullName }
			}
			
			# Inject post-install scripts and set the hostname.
			Inject-PostInstall -WindowsDrive $windrive -ScriptFolder $scriptFolder -UnattendDefaultPath $unattendFallback
			Set-UnattendHostname -WindowsDrive $windrive -Hostname $hostnameRaw
		}
		
		Write-UiLog ("Provisioning for {0} is complete." -f $targetdrive)
		Show-Info ("Provisioning for {0} is complete." -f $targetdrive)
	}
	catch
	{
		Write-UiLog "GO action failed: $($\_.Exception.Message)" -Level ERROR
		Show-Error "Imaging failed:\`r\`n$($\_.Exception.Message)"
	}
}

#endregion

#region ---- Button: Capture image (button1_Click) ----

# Event handler for the "Capture image" button.
$button1_Click = {
	try
	{
		# Get user input for the capture operation.
		if (-not $listbox2.SelectedItem) { Show-Warn "Select a disk line from the list."; return }
		if ($textbox2.TextLength -eq 0) { Show-Warn "Enter an image name."; return }
		
		$diskLine = $listbox2.SelectedItem
		# Parse the disk number from the selected line in the listbox.
		$diskNumber = ($diskLine -split '\\s\*-')\[0\].Trim() -as \[int\]
		if ($null -eq $diskNumber) { Show-Warn "Could not parse disk number from selection."; return }
		
		$imageName = $textbox2.Text
		$saveFolder = Join-Path $ssismain 'tbi_images'
		if (-not (Test-Path $saveFolder -PathType Container)) { Show-Error "Image save folder missing:\`r\`n$saveFolder"; return }
		
		$imagew = Join-Path $ssismain 'apps\\ImageW_LD\\imagew.exe'
		if (-not (Test-Path $imagew -PathType Leaf)) { Show-Error "imagew.exe not found:\`r\`n$imagew"; return }
		
		# Confirm the capture operation with the user.
		$summary = @"
Disk line:       $diskLine
Disk number:     $diskNumber
Image file name: $imageName.tbi
Tool:            $imagew
Save folder:     $saveFolder
"@
		if (-not (Confirm-YesNo $summary 'Confirm Capture')) { Write-UiLog 'User cancelled capture.' -Level WARN; return }
		
		# Start the image capture process.
		$args = "/b /rb:0 /d:{0} /f:{1}" -f $diskNumber, ('"{0}"' -f (Join-Path $saveFolder ($imageName + '.tbi')))
		$p = Start-Process -FilePath $imagew -ArgumentList $args -Wait -PassThru -WindowStyle Hidden
		if ($p.ExitCode -eq 0)
		{
			Write-UiLog "Capture complete: $imageName.tbi => $saveFolder"
			Show-Info "Capture complete."
		}
		else
		{
			Write-UiLog "Capture exited with code $($p.ExitCode)" -Level WARN
			Show-Warn "Capture finished with exit code $($p.ExitCode)."
		}
	}
	catch
	{
		Write-UiLog "Capture failed: $($\_.Exception.Message)" -Level ERROR
		Show-Error "Capture failed:\`r\`n$($\_.Exception.Message)"
	}
}

#endregion

