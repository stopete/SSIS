# Event handler for the DaRT button.
$button5_Click = {
	try
	{
		Write-UiLog "Launching Microsoft DaRT..."
		Launch-DART
	}
	catch
	{
		Write-UiLog "DaRT launch failed: $($\_.Exception.Message)" -Level ERROR
		Show-Error "DaRT launch failed:\`r\`n$($\_.Exception.Message)"
	}
}

# Event handler for the Farbar Recovery Scan Tool (FRST) button.
$button10_Click = {
	try
	{
		$frstDir = Join-Path $ssismain 'apps\\FarbarRecoveryScanTool'
		$frstPath = Join-Path $frstDir  'FRST64.exe'
		
		if (-not (Test-Path $frstPath -PathType Leaf))
		{
			Show-Warn "FRST64.exe not found at:\`r\`n$frstPath"
			return
		}
		
		Write-UiLog "Starting FRST: $frstPath"
		Start-Process -FilePath $frstPath -WorkingDirectory $frstDir -WindowStyle Normal
	}
	catch
	{
		Write-UiLog "FRST launch failed: $($\_.Exception.Message)" -Level ERROR
		Show-Error "FRST launch failed:\`r\`n$($\_.Exception.Message)"
	}
}

# Event handler for the BitLocker Tool button.
$button9_Click = {
	try
	{
		$blDir = Join-Path $ssismain 'apps\\BitLockerTool'
		$blPath = Join-Path $blDir    'BitLockerTool.ps1'
		
		if (-not (Test-Path $blPath -PathType Leaf))
		{
			Show-Warn "BitLockerTool.ps1 not found at:\`r\`n$blPath"
			return
		}
		
		Write-UiLog "Starting BitLockerTool: $blPath"
		Start-Process -FilePath 'powershell.exe' \`
					  -ArgumentList ('-NoProfile -ExecutionPolicy Bypass -File "{0}"' -f $blPath) \`
					  -WorkingDirectory $blDir \`
					  -WindowStyle Normal
	}
	catch
	{
		Write-UiLog "BitLockerTool launch failed: $($\_.Exception.Message)" -Level ERROR
		Show-Error "BitLockerTool launch failed:\`r\`n$($\_.Exception.Message)"
	}
}

