# Event handler for a helper button to update the hostname in a script.
$button7_Click = {
	try
	{
		$scriptFolder = Get-SelectedScriptFolder
		if (-not $scriptFolder) { return }
		$hostnameRaw = $textbox1.Text
		if (\[string\]::IsNullOrWhiteSpace($hostnameRaw)) { Show-Warn 'Enter a computer name.'; return }
		Update-RenameComputerScript -ScriptFolder $scriptFolder -NewComputerName $hostnameRaw
		Show-Info "Script updated with hostname: $hostnameRaw"
	}
	catch
	{
		Write-UiLog "Set hostname in script failed: $($\_.Exception.Message)" -Level ERROR
	}
}

